# --- AI STORY SERVICE (Bridge to 7900 XTX) ---
# The URL where your FastAPI/Ollama service is running
AI_SERVICE_URL=http://127.0.0.1:8001/generate
# Your unique API Key (Change this in your real .env!)
API_KEY=your_secret_key_here

# --- DJANGO SETTINGS ---
# Set to True for development, False for production
DEBUG=True
# Use a long, random string for your real SECRET_KEY
SECRET_KEY=django-insecure-placeholder-key

# .env.example
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kyoto_db
OLLAMA_BASE_URL=http://18.191.123.246:8001  # Your EC2 Relay
API_KEY=your_shared_key